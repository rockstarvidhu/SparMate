{
  "expo": {
    "name": "SparMate",
    "slug": "sparmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sparmate.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SparMate uses your location to find nearby sparring partners."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#111111"
      },
      "package": "com.sparmate.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SparMate uses your location to find nearby sparring partners."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "de63a9e6-2c58-4a78-b497-cac8f330c221"
      }
    },
    "owner": "sparmate"
  }
}
